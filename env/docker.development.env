# Docker hot-reload profile backed by the Dockerized platform-admin-api service.
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0
PLATFORM_ADMIN_ENVIRONMENT=development
PLATFORM_ADMIN_LOG_LEVEL=debug
PLATFORM_ADMIN_WEB_HOSTNAME=0.0.0.0
PLATFORM_ADMIN_WEB_PORT=3000
PLATFORM_ADMIN_API_BASE_URL=http://platform-admin-api:8080
PLATFORM_ADMIN_API_MODE=real
PLATFORM_ADMIN_API_MOCK=0
PLATFORM_ADMIN_COOKIE_SECURE=false
PLATFORM_ADMIN_REQUEST_TIMEOUT_MS=15000
PLATFORM_ADMIN_DEFAULT_PAGE_SIZE=25
NEXT_PUBLIC_JOB_POLL_INTERVAL_MS=5000
