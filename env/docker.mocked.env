# Docker hot-reload profile with the built-in current-contract mock adapter.
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0
PLATFORM_ADMIN_ENVIRONMENT=mocked
PLATFORM_ADMIN_LOG_LEVEL=debug
PLATFORM_ADMIN_WEB_HOSTNAME=0.0.0.0
PLATFORM_ADMIN_WEB_PORT=3000
PLATFORM_ADMIN_API_BASE_URL=http://127.0.0.1:8080
PLATFORM_ADMIN_API_MODE=mock
PLATFORM_ADMIN_API_MOCK=1
PLATFORM_ADMIN_COOKIE_SECURE=false
PLATFORM_ADMIN_REQUEST_TIMEOUT_MS=15000
PLATFORM_ADMIN_DEFAULT_PAGE_SIZE=25
NEXT_PUBLIC_JOB_POLL_INTERVAL_MS=1000
